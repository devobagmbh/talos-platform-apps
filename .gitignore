# Render-Output
rendered/
**/rendered/
*.rendered.yaml

# Helm-Chart-Caches
charts/*.tgz
**/charts/*.tgz
.helmcache/

# SBOM/Provenance-Artefakte (werden via OCI publiziert, nicht committed)
*.cdx.json
*.spdx.json
*.intoto.jsonl

# Scan-Artefakte (von scan:trivy / scan:snyk, lokal generiert)
trivy-results.sarif
snyk-results.sarif

# SOPS-Decryption-Tempfiles
*.dec
*.dec.yaml

# OS / Editor
.DS_Store
.vscode/
.idea/
*.swp
*~

# Local-only Konfiguration
.env

# Lokales Dev-Setup (mkcert-CA-Kopien, lokale Cluster-Daten)
.mkcert/

# Devbox / direnv State
.devbox/
.direnv/

# Claude Code — personal/local
.claude/settings.local.json
.claude/.DS_Store
.claude/reviews/
.claude/worktrees/
.claude/plans/

# Runtime state (subagent briefs/summaries, progress.json, transient logs)
.work/

# Scratch / planning notes (not part of the published catalog, not linted)
/Plans/

# Verzeichnis-Skelett für Reviews behalten (Hook setzt es voraus)
!.claude/reviews/.gitkeep
.mkcert-registry/
.ansible/

# Pinned openknowledge CLI, installed by `task okf:install` (not a Nix/devbox
# package — the one carve-out to CI convention 1). Version + checksum are pinned
# in the Taskfile; the binary itself is never committed.
.okf/
