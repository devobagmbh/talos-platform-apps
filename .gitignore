# Render output
rendered/
**/rendered/
*.rendered.yaml

# Helm chart caches
charts/*.tgz
**/charts/*.tgz
.helmcache/

# SBOM/provenance artifacts (published via OCI, not committed)
*.cdx.json
*.spdx.json
*.intoto.jsonl

# Scan artifacts (from scan:trivy / scan:snyk, generated locally)
trivy-results.sarif
snyk-results.sarif

# SOPS decryption tempfiles
*.dec
*.dec.yaml

# OS / Editor
.DS_Store
.vscode/
.idea/
*.swp
*~

# Local-only configuration
.env

# Local dev setup (mkcert CA copies, local cluster data)
.mkcert/

# Devbox / direnv State
.devbox/
.direnv/

# Claude Code — personal/local
.claude/settings.local.json
.claude/.DS_Store
.claude/reviews/
.claude/worktrees/
.claude/plans/

# Runtime state (subagent briefs/summaries, progress.json, transient logs)
.work/

# Scratch / planning notes (not part of the published catalog, not linted)
/Plans/

# Keep the directory skeleton for reviews (the hook requires it)
!.claude/reviews/.gitkeep
.mkcert-registry/
.ansible/

# Pinned openknowledge CLI, installed by `task okf:install` (not a Nix/devbox
# package — the one carve-out to CI convention 1). Version + checksum are pinned
# in the Taskfile; the binary itself is never committed.
.okf/
