# Aktiviert die Devbox-Umgebung beim cd in dieses Repo.
# Voraussetzung: direnv installiert + Shell-Hook gesetzt (https://direnv.net/docs/hook.html).
# Erste Aktivierung: `direnv allow`.

eval "$(devbox generate direnv --print-envrc)"

# SOPS age-Key-Pfad. Auf macOS sucht sops via os.UserConfigDir() in
# ~/Library/Application Support/ statt ~/.config/ — daher explizit setzen,
# sonst findet sops den Key nicht ("no key found"). Portabel via $HOME.
export SOPS_AGE_KEY_FILE="$HOME/.config/sops/age/keys.txt"

[ -f .envrc.local ] && source_env .envrc.local
