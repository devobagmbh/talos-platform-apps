{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "kubernetes-helm@latest",
    "kubectl@latest",
    "kustomize@latest",
    "cosign@latest",
    "oras@latest",
    "syft@latest",
    "trivy@latest",
    "conftest@latest",
    "kubeconform@latest",
    "gitleaks@8.30.1",
    "yamllint@latest",
    "markdownlint-cli@latest",
    "go-task@latest",
    "yq@latest",
    "jq@latest",
    "sops@latest",
    "age@latest",
    "talosctl@1.13.3",
    "argocd@latest",
    "kubectx@latest",
    "gettext@latest",
    "mkcert@latest",
    "check-jsonschema@latest",
    "watchexec@latest",
    "crossplane-cli@latest",
    "lefthook@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'talos-platform-apps devbox-shell aktiv — \"task --list\" für verfügbare Tasks'",
      "if [ -f lefthook.yml ] && [ ! -f .git/hooks/pre-commit ]; then echo 'Note: git hooks not yet installed. Run: lefthook install'; fi"
    ],
    "scripts": {}
  }
}
